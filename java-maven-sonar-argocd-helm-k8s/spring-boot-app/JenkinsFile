pipeline {

    agent {
        docker {
            image 'deepakf5/jenkins-agent:v1'
            args '--user root --entrypoint="" -v /var/run/docker.sock:/var/run/docker.sock'
            reuseNode true
        }
    }

    stages {
        stage('Test Container') {
            steps {
                sh '''
                    echo START
                    docker version
                    echo END
                '''
            }
        }
    }
}
