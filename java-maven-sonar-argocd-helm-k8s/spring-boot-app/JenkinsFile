pipeline {

    agent {
        docker {
            image 'deepakf5/jenkins-agent:v1'
            args '--entrypoint="" -v /var/run/docker.sock:/var/run/docker.sock'
            reuseNode true
        }
    }

    stages {

        stage('Test Container') {
            steps {
                sh '''
                    echo "START"
                    whoami
                    pwd
                    ls -la
                    java -version
                    mvn -version
                    git --version
                    echo "END"
                '''
            }
        }
    }
}
