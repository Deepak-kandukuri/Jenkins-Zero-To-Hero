pipeline {

    agent {
        docker {
            image 'deepakf5/jenkins-agent:v1'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {

        stage('Diagnostics') {
            steps {
                sh '''
                    echo "Current User"
                    whoami

                    echo "PWD"
                    pwd

                    echo "Shell"
                    ls -l /bin/sh

                    echo "TMP"
                    ls -ld /tmp

                    echo "Workspace"
                    ls -la

                    echo "Java"
                    java -version

                    echo "Maven"
                    mvn -version
                '''
            }
        }
    }
}
