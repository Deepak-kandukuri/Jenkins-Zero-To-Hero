pipeline {

    agent {
        docker {
            image 'deepakf5/jenkins-agent:v1'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock -v /tmp:/tmp'
        }
    }

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Diagnostics') {
            steps {
                sh '''
                    echo "===== START ====="
                    whoami
                    pwd
                    ls -la
                    echo "Java Version"
                    java -version
                    echo "Maven Version"
                    mvn -version
                    echo "Git Version"
                    git --version
                    echo "Docker Version"
                    docker version
                    echo "===== END ====="
                '''
            }
        }

    }

    post {
        always {
            cleanWs()
        }
    }
}
